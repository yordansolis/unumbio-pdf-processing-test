# =============================================================================
# PDF Bulletin Processing — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust the values for your environment.
# All variables have safe defaults in the source code, so only override
# what you actually need to change.
# =============================================================================


# -----------------------------------------------------------------------------
# I/O — File paths
# -----------------------------------------------------------------------------

# Path to the PDFPlumber JSON extraction of the bulletin (*_001.json).
INPUT_FILE=TECHNICAL-TEST/BUL_EM_TM_2024000007_001.json

# Destination path for the generated output JSON (*_002.json).
# The output/ directory is created automatically if it does not exist.
OUTPUT_FILE=output/BUL_EM_TM_2024000007_002.json


# -----------------------------------------------------------------------------
# Section filter  (src/section_filter.py)
# -----------------------------------------------------------------------------

# Exact text string that appears on the first page of the target section.
# The script starts collecting records from the page that contains this text.
SECTION_START=B.1.

# Exact text string that appears on the first page of the NEXT section.
# The script stops collecting records just before the page with this text.
SECTION_END=B.2.


# -----------------------------------------------------------------------------
# Column parser  (src/column_parser.py)
# -----------------------------------------------------------------------------

# Horizontal x0 threshold (in PDF points) that separates the left column
# from the right column.  Elements with x0 < COLUMN_SPLIT go left; the
# rest go right.  On a standard ~595 pt wide A4 page the midpoint is ~297,
# but the actual content split in this bulletin sits at ~255.
COLUMN_SPLIT=255.0

# Comma-separated list of text prefixes used to identify page header and
# footer elements that must be ignored (they are not record data).
# Note: trailing spaces are significant — "EUTM " avoids matching "EUTM" as
# a standalone value if that ever appears inside a field.
HEADER_PREFIXES=EUTM ,Part B,PART B,Part A,PART A


# -----------------------------------------------------------------------------
# Record builder  (src/record_builder.py)
# -----------------------------------------------------------------------------

# Comma-separated set of INID codes recognised as field labels.
# Any text element whose content is NOT in this set is treated as a value.
# INID codes are international standards for trademark bibliographic data:
#   111 — Registration number
#   151 — Registration date
#   450 — Publication date in bulletin
#   210 — Application number
#   400 — Prior publication reference
INID_CODES=111,151,450,210,400

# The INID code that signals the start of a new record.
# Every time this code is found, the current record is closed and a new
# one is opened.
RECORD_START_CODE=111

# Comma-separated INID codes whose values are stored as a list of strings
# (one entry per source line) instead of a single concatenated string.
# Use this for fields that can legitimately appear multiple times per record.
LIST_FIELDS=400

# Maximum vertical distance (in PDF points) between a label element and its
# value element for them to be considered "on the same line".
# Increase this value if label/value pairs are being missed; decrease it if
# unrelated elements are being incorrectly paired.
TOP_TOLERANCE=4.0
